# =============================================================================
# SurpriseMoi Backend - Docker Production Environment Configuration
# This file is ready to use - just copy to .env on your VPS
# =============================================================================

# Application
APP_NAME="Surprise Moi"
APP_ENV=production
APP_KEY=base64:QKuEMkAVWgF3pNq616gxvuPKxnWfYjM+hjRqV6I+8XI=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://dashboard.surprisemoi.com

# Mobile deep links / app links
DEEP_LINK_SHARE_BASE_URL=https://surprisemoi.com
ANDROID_APP_PACKAGE_NAME=com.surprisemoi.app
ANDROID_APP_SHA256_CERT_FINGERPRINTS=
ANDROID_APP_STORE_URL=https://play.google.com/store/apps/details?id=com.surprisemoi.app
IOS_APP_TEAM_ID=
IOS_APP_BUNDLE_ID=com.surprisemoi.app
IOS_APP_STORE_URL=https://apps.apple.com/app/id0000000000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Encryption
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=surprise_moi_db
DB_USERNAME=laraveluser
DB_PASSWORD="Gilash@123"

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=dashboard.surprisemoi.com

# Broadcasting
BROADCAST_CONNECTION=reverb

# Filesystem (use 'r2' in production, 'public' in local dev)
FILESYSTEM_DISK=r2

# Queue
QUEUE_CONNECTION=redis

# Cache
CACHE_STORE=redis

# Memcached
MEMCACHED_HOST=127.0.0.1

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD="Gilash@123"
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mail.teczaleel.com
MAIL_PORT=465
MAIL_USERNAME=verifications@surprisemoi.com
MAIL_PASSWORD=v3r!f!c@t!0ns
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=verifications@surprisemoi.com
MAIL_FROM_NAME="Surprise Moi"

# AWS (if using S3 for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=surprisemoi-media
CLOUDFLARE_R2_URL=
CLOUDFLARE_R2_ENDPOINT=

# Vite
VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSockets)
REVERB_APP_ID=349916
REVERB_APP_KEY=zgxbv1bjgg2vu7ad6gfc
REVERB_APP_SECRET=r6bjsk3dgbk91q6wqzzj
REVERB_HOST=dashboard.surprisemoi.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=dashboard.surprisemoi.com

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
PAYSTACK_SECRET_KEY=sk_live_your_secret_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
PAYSTACK_CALLBACK_URL=https://surprisemoi.com/payment/callback

# KairosAfrika SMS Service
KAIROSAFRIKA_API_KEY=U2FsdGVkX197aZqqwWAFOy4b7qjGTXLDSEkyq0vZHrU=
KAIROSAFRIKA_API_SECRET=XfsVRhmVTqJOZoixogtlSYm1623
KAIROSAFRIKA_API_URL=https://api.kairosafrika.com/v1
KAIROSAFRIKA_API_VERSION=2025-08-01
VITE_APP_NAME="${APP_NAME}"

#use for local development
# COMPOSE_FILE=docker-compose.local.yml

# Notification Logging Flags
# Set to true to log SMS/email instead of sending (for development/testing)
SMS_LOG_ONLY=false
EMAIL_LOG_ONLY=false

# Firebase Cloud Messaging (FCM)
FIREBASE_CREDENTIALS=firebase-credentials.json

# AI / Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# User Management Access
USER_MANAGEMENT_ACCESS_CODE=
USER_MANAGEMENT_TIMEOUT=300

# Backup Configuration
# GFS Retention Policy (Grandfather-Father-Son)
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
BACKUP_PATH=./backups
BACKUP_EXCLUDE_TABLES=migrations,password_reset_tokens,sessions,failed_jobs,job_batches,jobs,cache,cache_locks
BACKUP_NOTIFICATION_EMAIL=admin@example.com

# Laravel Octane (Swoole)
OCTANE_SERVER=swoole
OCTANE_HTTPS=true
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=6
OCTANE_MAX_REQUESTS=500
